# RoadWatch deterministic test IDs (copy into your runtime env as needed)
# Use these IDs when manually testing tool calls / demos.

# User / region
RW_TEST_CITIZEN_ID=CITIZEN-TEST-001
RW_TEST_COUNTRY_CODE=IN
RW_TEST_STATE_CODE=DL
RW_TEST_REGION_CODE=DL-ND
RW_TEST_DISTRICT_ID_DL_ND=b8b5c1d6-3f1e-4c73-9a09-2b2d74c18b6e
RW_TEST_DISTRICT_ID_MH_MUM=7a01f2c1-2e3b-4c19-9e15-0a1d0d66be33
RW_TEST_ROAD_TYPE=ARTERIAL

# Authorities
RW_TEST_AUTHORITY_ID=AUTH-DL
RW_TEST_AUTHORITY_ORG=NHAI

# Roads (must match gateway-api seed catalog)
RW_TEST_ROAD_ID_1=RD-DL-001
RW_TEST_ROAD_ID_2=RD-DL-002
RW_TEST_ROAD_ID_3=RD-MH-001
RW_TEST_ROAD_ID_4=RD-MH-002

# Complaints (used by local SQLite seed data)
RW_TEST_COMPLAINT_ID_1=COMPLAINT-TEST-0001
RW_TEST_COMPLAINT_ID_2=COMPLAINT-TEST-0002

# Proof / receipt verification (local proof hash used in seeded complaints)
RW_TEST_PROOF_HASH_SHA256=e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855

# Seeding controls
RW_SEED_DETERMINISTIC=1

# Fabric (Hyperledger) connection vars (required for `scripts/fabric-ledger.ts`)
# Do NOT commit real private keys; set these in your local shell/.env only.
# FABRIC_PEER_ENDPOINT=localhost:7051
# FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com
# FABRIC_TLS_CERT_PATH=/abs/path/to/peer/tls/ca.crt
# FABRIC_MSP_ID=CitizenOrgMSP
# FABRIC_IDENTITY_CERT_PATH=/abs/path/to/user/cert.pem
# FABRIC_IDENTITY_KEY_PATH=/abs/path/to/user/key.pem
# FABRIC_CHANNEL=mychannel
# FABRIC_CHAINCODE=roadwatch
