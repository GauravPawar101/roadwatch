# Fabric anchor consumer (local/dev)

# --- Upstash Kafka REST credentials ---
UPSTASH_KAFKA_REST_URL=https://replace-with-upstash-kafka-rest-url
UPSTASH_KAFKA_REST_USERNAME=replace-with-upstash-rest-username
UPSTASH_KAFKA_REST_PASSWORD=replace-with-upstash-rest-password

# --- Postgres (same DB as gateway-api) ---
# Example for docker-compose Postgres in this repo:
# postgres://roadwatch_admin:development_password@localhost:5433/roadwatch_local
DATABASE_URL=postgres://roadwatch_admin:development_password@localhost:5433/roadwatch_local

# --- Consumer identity (optional overrides) ---
KAFKA_CONSUMER_GROUP_ID=fabric-anchor-consumer-v1
# Must be unique per running instance
KAFKA_CONSUMER_INSTANCE_ID=fabric-anchor-local-1

# --- Hyperledger Fabric gateway ---
FABRIC_TLS_CERT_PATH=./path/to/tls/ca.crt
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.citizenorg.example.com
FABRIC_CHANNEL_NAME=roadwatch-channel
FABRIC_CHAINCODE_NAME=roadwatch

# X.509 identity for the gateway signer (CitizenOrg)
FABRIC_X509_CERT_PATH=./path/to/user/cert.pem
FABRIC_X509_KEY_PATH=./path/to/user/key.pem
