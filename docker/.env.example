# NEVER commit the real .env file exactly!

# [1] Core PostgreSql Node Lock physically
# Must securely align explicitly matching docker-compose.yml parameters securely natively
POSTGRES_PASSWORD=use-a-strong-randomized-string-here

# [2] Upstash Kafka (REST)
# Upstash Kafka REST uses HTTP with Basic auth.
#
# Minimum (what you said you have):
# - UPSTASH_KAFKA_REST_URL
# - UPSTASH_KAFKA_REST_TOKEN
#
# Where does the token come from?
# - If Upstash gives you a single "REST token" string, paste it directly.
# - If Upstash gives you REST username + password instead, leave TOKEN empty and fill USERNAME/PASSWORD.
UPSTASH_KAFKA_REST_URL=https://replace-with-upstash-kafka-rest-url
UPSTASH_KAFKA_REST_TOKEN=replace-with-upstash-rest-token

# Optional alternative auth (only if you have these instead of a token):
UPSTASH_KAFKA_REST_USERNAME=
UPSTASH_KAFKA_REST_PASSWORD=

# [3] Core JSON Web Token Signing boundaries securely inherently
# Structurally executed strictly locking backend requests exactly against forged local user execution arrays organically natively
JWT_SECRET=super_secret_cryptographic_private_key_do_not_share_ever
