{
  "name": "@roadwatch/mobile-host",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "pod-install": "cd ios && pod install",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm typecheck",
    "clean": "watchman watch-del-all && rm -rf node_modules && rm -rf ios/Pods && rm -rf ios/build"
  },
  "dependencies": {
    "@roadwatch/adapters": "workspace:*",
    "@roadwatch/config": "workspace:*",
    "@roadwatch/core": "workspace:*",
    "@roadwatch/feature-agent": "workspace:*",
    "@roadwatch/feature-complaint": "workspace:*",
    "@roadwatch/feature-map": "workspace:*",
    "@roadwatch/features": "workspace:*",
    "@roadwatch/providers": "workspace:*",
    "@roadwatch/storage-sqlite": "workspace:*",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "react-native-keychain": "^9.2.0",
    "react-native-quick-sqlite": "8.1.0",
    "react-native-safe-area-context": "^4.10.7",
    "react-native-screens": "^3.34.0",
    "react-native-config": "^1.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native/babel-preset": "0.73.0",
    "@react-native/metro-config": "0.73.0",
    "typescript": "^5.0.0"
  }
}
