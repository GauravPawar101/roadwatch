# gateway-api local dev
# Copy to .env and adjust as needed.

# Server
PORT=3000
NODE_ENV=development

# Postgres (docker-compose postgres publishes 5433->5432)
DATABASE_URL=postgres://roadwatch_admin:development_password@127.0.0.1:5433/roadwatch_local

# Auth
JWT_SECRET=local_development_cryptographic_secret
OTP_TTL_SECONDS=300
ALLOW_DEV_OTP_ECHO=true

# Optional PII protection (recommended)
# PHONE_HASH_PEPPER=some-long-random-string
# PHONE_ENC_KEY=base64-32-byte-key

# LLM (pick one)
# Gemini (hosted)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Ollama (local)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1

# llama.cpp server (OpenAI-compatible)
# LLAMACPP_BASE_URL=http://127.0.0.1:8080
# LLAMACPP_MODEL=llama

# Comma-separated priority list
LLM_FALLBACK_ORDER=gemini,ollama,llamacpp

# Kafka (optional; enables event publishing)
# UPSTASH_KAFKA_REST_URL=
# UPSTASH_KAFKA_REST_USERNAME=
# UPSTASH_KAFKA_REST_PASSWORD=

# Fabric (optional; used by Fabric components/scripts)
# NOTE: repo contains multiple naming schemes; prefer the *_IDENTITY_* + FABRIC_CHANNEL/FABRIC_CHAINCODE used by scripts/tests.
# FABRIC_PEER_ENDPOINT=peer0.example.com:7051
# FABRIC_PEER_HOST_ALIAS=peer0.example.com
# FABRIC_MSP_ID=RoadWatchMSP
# FABRIC_TLS_CERT_PATH=/abs/path/to/peer/tls/ca.crt
# FABRIC_IDENTITY_CERT_PATH=/abs/path/to/user/cert.pem
# FABRIC_IDENTITY_KEY_PATH=/abs/path/to/user/key.pem
# FABRIC_CHANNEL=roadwatch-india
# FABRIC_CHAINCODE=complaint-anchor
